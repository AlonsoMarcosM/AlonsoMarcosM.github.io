---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { profile } from '../data/site';
import { useTranslations, pick, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Ruta relativa al idioma (sin prefijo): '', 'projects' o 'projects/slug'. */
  path?: string;
  ogImage?: string;
}

const { lang, title, description, path = '', ogImage = '/img/og-default.png' } = Astro.props;
const t = useTranslations(lang);

const site = (Astro.site ? Astro.site.toString() : 'https://alonsomarcosm.github.io').replace(/\/$/, '');
const norm = path.replace(/^\/|\/$/g, '');
// Sin literales de plantilla anidados: rompen el scanner de @astrojs/compiler.
const buildUrl = (l: Lang) => site + '/' + l + (norm ? '/' + norm : '') + '/';
const canonical = buildUrl(lang);
const ogImageUrl = ogImage.startsWith('http') ? ogImage : site + ogImage;

const fontsHref =
  'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap';

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: pick(profile.role, lang),
  email: 'mailto:' + profile.email,
  url: site,
  address: { '@type': 'PostalAddress', addressLocality: pick(profile.location, lang) },
  sameAs: profile.socials.filter((s) => s.icon !== 'email').map((s) => s.href),
};
---

<!doctype html>
<html lang={lang} class="dark scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="es" href={buildUrl('es')} />
    <link rel="alternate" hreflang="en" href={buildUrl('en')} />
    <link rel="alternate" hreflang="x-default" href={buildUrl('en')} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href={fontsHref} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)}></script>

    <script is:inline>
      (function () {
        try {
          var theme = localStorage.getItem('theme');
          if (theme === 'light') document.documentElement.classList.remove('dark');
          else document.documentElement.classList.add('dark');
        } catch (e) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen font-sans">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-brand-500 focus:px-4 focus:py-2 focus:text-slate-950"
    >
      {t('skiplink')}
    </a>
    <Header lang={lang} path={norm} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

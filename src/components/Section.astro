---
interface Props {
  id?: string;
  title: string;
  subtitle?: string;
  /** Número de sección, p.ej. "01". */
  index?: string;
  class?: string;
}
const { id, title, subtitle, index, class: className = '' } = Astro.props;
---

<section id={id} class:list={['scroll-mt-20 py-16 sm:py-20', className]}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <div class="reveal mb-10">
      <h2 class="flex items-center gap-3 text-2xl font-bold tracking-tight sm:text-3xl">
        <span class="h-7 w-1.5 rounded-full bg-gradient-to-b from-brand-400 to-accent-500"></span>
        {title}
      </h2>
      {subtitle && <p class="mt-3 max-w-2xl text-slate-500 dark:text-slate-400">{subtitle}</p>}
    </div>
    <slot />
  </div>
</section>

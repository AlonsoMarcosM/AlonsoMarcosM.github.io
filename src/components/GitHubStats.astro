---
import Icon from './Icon.astro';
import { Icon as Iconify } from 'astro-icon/components';
interface Props {
  username: string;
  lang: 'es' | 'en';
}
const { username, lang } = Astro.props;
const tt = (es: string, en: string) => (lang === 'es' ? es : en);

// github-readme-stats (servicio público) con tema oscuro a juego.
const common = 'hide_border=true&bg_color=00000000&title_color=22d3ee&text_color=94a3b8&icon_color=22d3ee';
const statsUrl = `https://github-readme-stats.vercel.app/api?username=${username}&include_all_commits=true&count_private=true&show_icons=true&show=prs_merged_percent&${common}`;
const langsUrl = `https://github-readme-stats.vercel.app/api/top-langs/?username=${username}&layout=compact&langs_count=8&${common}`;
---

<div class="relative overflow-hidden rounded-3xl border border-slate-200 bg-white/60 p-6 backdrop-blur sm:p-8 dark:border-slate-800 dark:bg-slate-900/40">
  <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-400 via-accent-500 to-blue-500"></div>

  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-wide text-emerald-600 dark:text-emerald-300">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
        </span>
        {tt('Señal de GitHub en vivo', 'Live GitHub signal')}
      </span>
      <h2 class="mt-3 flex items-center gap-2 text-2xl font-bold tracking-tight sm:text-3xl">
        <Iconify name="lucide:activity" class="h-6 w-6 text-brand-500" />
        {tt('Estadísticas de código', 'Coding stats')}
      </h2>
      <p class="mt-1 text-slate-500 dark:text-slate-400">
        {tt('Snapshot en tiempo real desde GitHub.', 'Realtime snapshot directly from GitHub.')}
      </p>
    </div>
    <a
      href={`https://github.com/${username}`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex flex-none items-center gap-2 rounded-xl border border-slate-300 px-4 py-2.5 text-sm font-semibold transition hover:border-brand-400 hover:text-brand-500 dark:border-slate-700"
    >
      <Icon name="github" class="h-4 w-4" />
      {tt('Abrir perfil de GitHub', 'Open GitHub profile')}
      <Iconify name="lucide:arrow-up-right" class="h-4 w-4" />
    </a>
  </div>

  <div class="mt-6 grid items-center gap-4 lg:grid-cols-2">
    <div class="rounded-2xl border border-slate-200/70 bg-white/50 p-3 dark:border-slate-800 dark:bg-slate-900/40">
      <img
        src={statsUrl}
        alt={tt('Estadísticas de GitHub de ', 'GitHub stats for ') + username}
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer"
        onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden');"
        class="h-auto w-full"
      />
      <div class="grid hidden min-h-[176px] place-content-center rounded-xl bg-slate-950/5 p-5 text-center dark:bg-white/5">
        <Icon name="github" class="mx-auto h-7 w-7 text-brand-500" />
        <p class="mt-3 text-sm font-semibold text-slate-800 dark:text-slate-100">
          {tt('Estadísticas de GitHub no disponibles', 'GitHub stats unavailable')}
        </p>
        <p class="mx-auto mt-1 max-w-xs text-xs leading-relaxed text-slate-500 dark:text-slate-400">
          {tt('El servicio externo no respondió. El perfil sigue disponible en GitHub.', 'The external service did not respond. The profile is still available on GitHub.')}
        </p>
        <a
          href={`https://github.com/${username}`}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center justify-center gap-2 rounded-xl border border-slate-300 px-3 py-2 text-xs font-semibold transition hover:border-brand-400 hover:text-brand-500 dark:border-slate-700"
        >
          {tt('Abrir GitHub', 'Open GitHub')}
          <Iconify name="lucide:arrow-up-right" class="h-3.5 w-3.5" />
        </a>
      </div>
    </div>
    <div class="rounded-2xl border border-slate-200/70 bg-white/50 p-3 dark:border-slate-800 dark:bg-slate-900/40">
      <img
        src={langsUrl}
        alt={tt('Lenguajes más usados', 'Most used languages')}
        loading="lazy"
        decoding="async"
        referrerpolicy="no-referrer"
        onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden');"
        class="mx-auto h-auto w-full max-w-sm"
      />
      <div class="grid hidden min-h-[243px] place-content-center rounded-xl bg-slate-950/5 p-5 text-center dark:bg-white/5">
        <Iconify name="lucide:code-2" class="mx-auto h-7 w-7 text-brand-500" />
        <p class="mt-3 text-sm font-semibold text-slate-800 dark:text-slate-100">
          {tt('Lenguajes no disponibles', 'Languages unavailable')}
        </p>
        <p class="mx-auto mt-1 max-w-xs text-xs leading-relaxed text-slate-500 dark:text-slate-400">
          {tt('La imagen externa no pudo cargarse en este momento.', 'The external image could not be loaded right now.')}
        </p>
      </div>
    </div>
  </div>
</div>

---
import { pick, useTranslations, type Lang } from '../i18n/utils';
import type { Experience } from '../data/experience';

interface Props {
  item: Experience;
  lang: Lang;
}
const { item, lang } = Astro.props;
const t = useTranslations(lang);

const locale = lang === 'es' ? 'es-ES' : 'en-US';
function fmt(value: string): string {
  const [y, m] = value.split('-').map(Number);
  const d = new Date(y, (m ?? 1) - 1, 1);
  const s = d.toLocaleDateString(locale, { month: 'short', year: 'numeric' });
  return s.charAt(0).toUpperCase() + s.slice(1);
}
const period = `${fmt(item.period.from)} – ${item.period.to ? fmt(item.period.to) : t('experience.present')}`;
const highlights = pick(item.highlights, lang);
---

<article class="relative pl-8">
  <span class="absolute left-0 top-1.5 h-3 w-3 rounded-full border-2 border-brand-500 bg-white dark:bg-slate-950"></span>
  <span class="absolute left-[5px] top-5 h-[calc(100%-1rem)] w-px bg-slate-200 dark:bg-slate-800"></span>

  <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline">
    <h3 class="text-lg font-semibold">
      {item.company}
    </h3>
    <span class="font-mono text-xs text-slate-400">{period}</span>
  </div>
  <p class="text-sm font-medium text-brand-600 dark:text-brand-400">{pick(item.role, lang)}</p>
  <p class="mt-1 text-xs text-slate-400">{pick(item.location, lang)}</p>

  <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{pick(item.summary, lang)}</p>

  <ul class="mt-3 space-y-1.5">
    {
      highlights.map((h) => (
        <li class="flex gap-2 text-sm text-slate-600 dark:text-slate-400">
          <span class="mt-2 h-1 w-1 flex-none rounded-full bg-brand-500"></span>
          <span>{h}</span>
        </li>
      ))
    }
  </ul>

  <div class="mt-3 flex flex-wrap gap-1.5">
    {
      item.tags.map((tag) => (
        <span class="rounded-md border border-slate-200 px-2 py-0.5 font-mono text-[11px] text-slate-500 dark:border-slate-700 dark:text-slate-400">
          {tag}
        </span>
      ))
    }
  </div>
</article>

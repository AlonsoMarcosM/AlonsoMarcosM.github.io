---
import TechBadge from './TechBadge.astro';
import { pick, useTranslations, type Lang } from '../i18n/utils';
import type { Experience } from '../data/experience';

interface Props {
  item: Experience;
  lang: Lang;
  /** Posición en la línea temporal (0 = más reciente) y total de hitos. */
  index?: number;
  total?: number;
}
const { item, lang, index = 0, total = 1 } = Astro.props;
const t = useTranslations(lang);

// La línea temporal es un único gradiente continuo cian -> azul -> índigo
// que avanza a lo largo de toda la carrera; cada tramo toma su porción.
const palette = ['#22d3ee', '#3b82f6', '#6366f1', '#8b5cf6'];
const fromColor = palette[Math.min(index, palette.length - 1)];
const isLast = index === total - 1;
const toColor = isLast ? 'transparent' : palette[Math.min(index + 1, palette.length - 1)];
const lineStyle = `background: linear-gradient(to bottom, ${fromColor}, ${toColor});`;

const locale = lang === 'es' ? 'es-ES' : 'en-US';
function fmt(value: string): string {
  const [y, m] = value.split('-').map(Number);
  const d = new Date(y, (m ?? 1) - 1, 1);
  const s = d.toLocaleDateString(locale, { month: 'short', year: 'numeric' });
  return s.charAt(0).toUpperCase() + s.slice(1);
}
const period = `${fmt(item.period.from)} – ${item.period.to ? fmt(item.period.to) : t('experience.present')}`;
const highlights = pick(item.highlights, lang);

const stop = ['de', 'del', 'la', 'el', 'y', 'and', 'of'];
const initials = item.company
  .split(/\s+/)
  .filter((w) => !stop.includes(w.toLowerCase()))
  .slice(0, 2)
  .map((w) => w[0])
  .join('')
  .toUpperCase();
const current = item.period.to === null;
---

<article class="reveal group relative flex gap-4 pl-1">
  <div class="flex flex-col items-center">
    {
      item.logo ? (
        <span class="grid h-12 w-12 flex-none place-items-center overflow-hidden rounded-xl bg-white p-1.5 shadow-[0_0_0_5px_rgba(6,182,212,0.14)] ring-1 ring-slate-200 transition-transform duration-300 group-hover:scale-110 dark:ring-white/10">
          <img src={item.logo} alt={item.company} class="h-full w-full object-contain" loading="lazy" />
        </span>
      ) : (
        <span class="grid h-12 w-12 flex-none place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-accent-500 font-mono text-sm font-bold text-slate-950 shadow-[0_0_0_5px_rgba(6,182,212,0.18)] transition-transform duration-300 group-hover:scale-110">
          {initials}
        </span>
      )
    }
    <span class="mt-2 w-1 flex-1 rounded-full" style={lineStyle}></span>
  </div>

  <div class="pb-10">
    <div class="flex flex-col justify-between gap-1 sm:flex-row sm:items-baseline">
      <h3 class="flex items-center gap-2 text-lg font-semibold">
        {item.company}
        {current && (
          <span class="rounded-full bg-brand-500/15 px-2 py-0.5 text-[11px] font-medium text-brand-600 dark:text-brand-300">
            {t('experience.present')}
          </span>
        )}
      </h3>
      <span class="font-mono text-xs text-slate-400">{period}</span>
    </div>
    <p class="text-sm font-medium text-brand-600 dark:text-brand-400">{pick(item.role, lang)}</p>
    <p class="mt-1 text-xs text-slate-400">{pick(item.location, lang)}</p>

    <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{pick(item.summary, lang)}</p>

    <ul class="mt-3 space-y-1.5">
      {
        highlights.map((h) => (
          <li class="flex gap-2 text-sm text-slate-600 dark:text-slate-400">
            <span class="mt-2 h-1 w-1 flex-none rounded-full bg-brand-500"></span>
            <span>{h}</span>
          </li>
        ))
      }
    </ul>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {item.tags.map((tag) => <TechBadge label={tag} size="sm" link />)}
    </div>
  </div>
</article>

---
import Icon from './Icon.astro';
import { Icon as Iconify } from 'astro-icon/components';
import ThemeToggle from './ThemeToggle.astro';
import LangSwitcher from './LangSwitcher.astro';
import { profile, navSections } from '../data/site';
import { localePath, useTranslations, type Lang } from '../i18n/utils';
import type { UIKey } from '../i18n/ui';

interface Props {
  lang: Lang;
  /** Ruta relativa al idioma (sin prefijo). */
  path?: string;
}
const { lang, path = '' } = Astro.props;
const t = useTranslations(lang);
const home = localePath(lang);
const initials = profile.name
  .split(' ')
  .map((w) => w[0])
  .slice(0, 2)
  .join('');
---

<header
  class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur-md dark:border-slate-800/70 dark:bg-slate-950/80"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href={home} class="flex items-center gap-2 font-semibold tracking-tight">
      <span
        class="grid h-8 w-8 place-items-center rounded-lg bg-brand-500 font-mono text-sm font-bold text-slate-950"
        >{initials}</span
      >
      <span class="hidden sm:inline">{profile.name}</span>
    </a>

    <div class="hidden items-center gap-1 md:flex">
      {
        navSections.map((s) => (
          <a
            href={`${home}#${s.id}`}
            class="inline-flex items-center gap-1.5 rounded-md px-3 py-2 text-sm text-slate-600 transition hover:text-brand-500 dark:text-slate-300 dark:hover:text-brand-400"
          >
            <Iconify name={s.icon} class="h-4 w-4 opacity-70" />
            {t(s.key as UIKey)}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-2">
      <LangSwitcher lang={lang} path={path} />
      <ThemeToggle lang={lang} />
      <button
        id="menu-toggle"
        type="button"
        aria-label="Menu"
        aria-expanded="false"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 text-slate-600 md:hidden dark:border-slate-700 dark:text-slate-300"
      >
        <Icon name="menu" class="h-5 w-5" />
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-200 px-4 py-2 md:hidden dark:border-slate-800">
    {
      navSections.map((s) => (
        <a
          href={`${home}#${s.id}`}
          class="flex items-center gap-2.5 rounded-md px-3 py-2 text-sm text-slate-600 transition hover:bg-slate-100 hover:text-brand-500 dark:text-slate-300 dark:hover:bg-slate-900"
        >
          <Iconify name={s.icon} class="h-4 w-4 opacity-70" />
          {t(s.key as UIKey)}
        </a>
      ))
    }
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function () {
      var open = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
    });
    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        menu.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>

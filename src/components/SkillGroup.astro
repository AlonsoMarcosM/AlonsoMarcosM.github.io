---
import { Icon } from 'astro-icon/components';
import TechBadge from './TechBadge.astro';
import { pick, type Lang } from '../i18n/utils';
import type { SkillGroup } from '../data/skills';

interface Props {
  group: SkillGroup;
  lang: Lang;
}
const { group, lang } = Astro.props;
const title = pick(group.title, lang).toLowerCase();

function groupIcon(t: string): string {
  if (t.includes('gobern') || t.includes('governance') || t.includes('calidad') || t.includes('quality')) return 'lucide:shield-check';
  if (t.includes('big data')) return 'lucide:layers';
  if (t.includes('cloud') || t.includes('devops')) return 'lucide:cloud';
  if (t.includes('ia') || t.includes('ai') || t.includes('automat')) return 'lucide:workflow';
  if (t.includes('gestión') || t.includes('management') || t.includes('idioma') || t.includes('languages')) return 'lucide:briefcase';
  return 'lucide:database';
}
---

<div class="reveal rounded-2xl border border-slate-200 bg-white/70 p-5 backdrop-blur transition hover:border-brand-400/40 dark:border-slate-800 dark:bg-slate-900/50">
  <h3 class="mb-4 flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
    <Icon name={groupIcon(title)} class="h-4 w-4" />
    {pick(group.title, lang)}
  </h3>
  <div class="flex flex-wrap gap-2">
    {group.items.map((item) => <TechBadge label={item} size="sm" link />)}
  </div>
</div>

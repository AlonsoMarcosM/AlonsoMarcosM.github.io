---
import { pick, type Lang } from '../i18n/utils';
import type { SkillGroup } from '../data/skills';

interface Props {
  group: SkillGroup;
  lang: Lang;
}
const { group, lang } = Astro.props;
---

<div class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-900/50">
  <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
    {pick(group.title, lang)}
  </h3>
  <div class="flex flex-wrap gap-2">
    {
      group.items.map((item) => (
        <span class="rounded-lg bg-slate-100 px-2.5 py-1 font-mono text-xs text-slate-700 dark:bg-slate-800 dark:text-slate-300">
          {item}
        </span>
      ))
    }
  </div>
</div>

---
import Icon from './Icon.astro';
import { profile } from '../data/site';
import { pick, localePath, useTranslations, type Lang } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const cvHref = lang === 'es' ? profile.cv.es : profile.cv.en;
---

<section class="relative overflow-hidden">
  <div class="bg-grid pointer-events-none absolute inset-0 opacity-60 [mask-image:radial-gradient(ellipse_at_top,black,transparent_70%)]"></div>
  <div
    class="pointer-events-none absolute -top-32 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-brand-500/20 blur-3xl"
  >
  </div>

  <div class="relative mx-auto max-w-5xl px-4 pb-12 pt-16 sm:px-6 sm:pt-24">
    <div class="grid items-center gap-10 md:grid-cols-[1fr_auto]">
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-brand-500/30 bg-brand-500/10 px-3 py-1 text-xs font-medium text-brand-600 dark:text-brand-300"
        >
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500"></span>
          </span>
          {t('hero.available')}
        </span>

        <h1 class="mt-5 text-4xl font-bold tracking-tight sm:text-5xl">{profile.name}</h1>
        <p class="mt-3 font-mono text-base text-brand-600 sm:text-lg dark:text-brand-400">
          {pick(profile.role, lang)}
        </p>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-slate-600 dark:text-slate-300">
          {pick(profile.tagline, lang)}
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href={localePath(lang, 'projects')}
            class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400"
          >
            {t('hero.cta.projects')}
            <Icon name="arrow-right" class="h-4 w-4" />
          </a>
          <a
            href={`mailto:${profile.email}`}
            class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-5 py-2.5 text-sm font-semibold transition hover:border-brand-400 hover:text-brand-500 dark:border-slate-700"
          >
            <Icon name="email" class="h-4 w-4" />
            {t('hero.cta.contact')}
          </a>
          <a
            href={cvHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-500 transition hover:text-brand-500 dark:text-slate-400"
          >
            <Icon name="download" class="h-4 w-4" />
            {t('hero.cta.cv')}
          </a>
        </div>

        <div class="mt-8 flex items-center gap-5 text-slate-400">
          {
            profile.socials.map((s) => (
              <a
                href={s.href}
                aria-label={s.label}
                class="transition hover:text-brand-500"
                target={s.icon === 'email' ? undefined : '_blank'}
                rel={s.icon === 'email' ? undefined : 'noopener noreferrer'}
              >
                <Icon name={s.icon} class="h-5 w-5" />
              </a>
            ))
          }
          <span class="inline-flex items-center gap-1.5 text-sm">
            <Icon name="map-pin" class="h-4 w-4" />
            {pick(profile.location, lang)}
          </span>
        </div>
      </div>

      <div class="order-first justify-self-center md:order-last">
        <div class="group relative">
          <div
            class="absolute -inset-1 rounded-full bg-gradient-to-tr from-brand-500 via-brand-400 to-cyan-300 opacity-70 blur-md transition group-hover:opacity-100"
          >
          </div>
          <img
            src="/img/alonso.jpg"
            alt={profile.name}
            width="240"
            height="240"
            loading="eager"
            class="relative h-44 w-44 rounded-full border-2 border-white/80 object-cover object-center grayscale transition duration-500 group-hover:grayscale-0 sm:h-60 sm:w-60 dark:border-slate-800"
          />
        </div>
      </div>
    </div>
  </div>
</section>

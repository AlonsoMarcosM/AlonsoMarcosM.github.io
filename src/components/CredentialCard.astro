---
import { Icon } from 'astro-icon/components';

interface Props {
  type: 'edu' | 'cert';
  typeLabel: string;
  logo?: string;
  title: string;
  sub: string;
  note?: string;
  alt: string;
}
const { type, typeLabel, logo, title, sub, note, alt } = Astro.props;
const isEdu = type === 'edu';
const fallbackIcon = isEdu ? 'lucide:graduation-cap' : 'lucide:badge-check';
// Clases literales completas (Tailwind no detecta nombres interpolados).
const topbar = isEdu ? 'from-brand-400 to-brand-500/0' : 'from-accent-400 to-accent-500/0';
const pill = isEdu
  ? 'bg-brand-500/10 text-brand-600 dark:text-brand-300'
  : 'bg-accent-500/10 text-accent-600 dark:text-accent-300';
const iconColor = isEdu ? 'text-brand-500' : 'text-accent-500';
---

<article class="reveal group relative flex gap-4 overflow-hidden rounded-2xl border border-slate-200 bg-white/70 p-5 backdrop-blur transition hover:-translate-y-0.5 hover:shadow-lg hover:shadow-slate-900/5 dark:border-slate-800 dark:bg-slate-900/50">
  <div class:list={['pointer-events-none absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r', topbar]}></div>

  <span class="grid h-14 w-14 flex-none place-items-center overflow-hidden rounded-xl bg-white p-2 ring-1 ring-slate-200 dark:ring-white/10">
    {
      logo ? (
        <img src={logo} alt={alt} class="h-full w-full object-contain" loading="lazy" />
      ) : (
        <Icon name={fallbackIcon} class:list={['h-7 w-7', iconColor]} />
      )
    }
  </span>

  <div class="min-w-0">
    <span class:list={['inline-block rounded-full px-2 py-0.5 text-[11px] font-medium', pill]}>
      {typeLabel}
    </span>
    <p class="mt-1.5 font-medium leading-snug">{title}</p>
    <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">{sub}</p>
    {note && (
      <span class="mt-2 inline-block rounded-full bg-slate-100 px-2 py-0.5 text-[11px] text-slate-500 dark:bg-slate-800 dark:text-slate-400">
        {note}
      </span>
    )}
  </div>
</article>

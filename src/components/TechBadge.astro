---
import { Icon } from 'astro-icon/components';
import { getTech } from '../data/techIcons';

interface Props {
  label: string;
  /** 'sm' para tarjetas, 'md' para la página de detalle. */
  size?: 'sm' | 'md';
}
const { label, size = 'sm' } = Astro.props;
const tech = getTech(label);
const pad = size === 'md' ? 'pl-1.5 pr-3 py-1 text-sm' : 'pl-1 pr-2.5 py-0.5 text-xs';
const flat = size === 'md' ? 'px-3 py-1.5 text-sm' : 'px-2.5 py-1 text-xs';
const tile = size === 'md' ? 'h-6 w-6' : 'h-5 w-5';
const ico = size === 'md' ? 'h-4 w-4' : 'h-3.5 w-3.5';
---

{
  tech ? (
    <span
      class:list={[
        'inline-flex items-center gap-1.5 rounded-lg border font-mono transition',
        'border-slate-200 bg-slate-50 text-slate-700',
        'dark:border-slate-700/70 dark:bg-slate-800/60 dark:text-slate-200',
        'hover:border-brand-400/70',
        pad,
      ]}
    >
      <span class={`grid ${tile} flex-none place-items-center rounded-md bg-white ring-1 ring-slate-200/70 dark:ring-white/10`}>
        <Icon name={tech.icon} class={ico} style={`color:${tech.color}`} />
      </span>
      {label}
    </span>
  ) : (
    <span
      class:list={[
        'inline-flex items-center rounded-lg border font-mono transition',
        'border-slate-200 bg-slate-50 text-slate-700',
        'dark:border-slate-700/70 dark:bg-slate-800/60 dark:text-slate-300',
        'hover:border-brand-400/70 hover:text-brand-600 dark:hover:text-brand-300',
        flat,
      ]}
    >
      {label}
    </span>
  )
}

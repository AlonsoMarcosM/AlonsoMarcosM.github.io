---
import { Icon } from 'astro-icon/components';
import { getTech } from '../data/techIcons';

interface Props {
  label: string;
  /** 'sm' para tarjetas, 'md' para la página de detalle. */
  size?: 'sm' | 'md';
  /** Si true y hay doc oficial, el chip enlaza a la documentación. */
  link?: boolean;
}
const { label, size = 'sm', link = false } = Astro.props;
const tech = getTech(label);
const hasIcon = !!tech?.icon;
const doc = tech?.doc;
const isLink = link && !!doc;
const Tag = isLink ? 'a' : 'span';

const padIcon = size === 'md' ? 'pl-2 pr-3 py-1.5 text-sm' : 'pl-1.5 pr-2.5 py-1 text-[13px]';
const padFlat = size === 'md' ? 'px-3.5 py-1.5 text-sm' : 'px-3 py-1 text-[13px]';
const tile = size === 'md' ? 'h-7 w-7' : 'h-6 w-6';
const ico = size === 'md' ? 'h-[18px] w-[18px]' : 'h-4 w-4';
const ext = size === 'md' ? 'h-3.5 w-3.5' : 'h-3 w-3';

const base =
  'group/badge inline-flex items-center gap-1.5 rounded-lg border font-mono transition border-slate-200 bg-slate-50 text-slate-700 dark:border-slate-700/70 dark:bg-slate-800/60 dark:text-slate-200 hover:border-brand-400/70';
---

<Tag
  class:list={[base, hasIcon ? padIcon : padFlat, isLink && 'hover:-translate-y-0.5 hover:text-brand-600 dark:hover:text-brand-300']}
  href={isLink ? doc : undefined}
  target={isLink ? '_blank' : undefined}
  rel={isLink ? 'noopener noreferrer' : undefined}
  title={isLink ? `${label} · docs` : undefined}
>
  {
    hasIcon && (
      <span class={`grid ${tile} flex-none place-items-center rounded-md bg-white ring-1 ring-slate-200/70 dark:ring-white/10`}>
        <Icon name={tech!.icon!} class={ico} style={`color:${tech!.color}`} />
      </span>
    )
  }
  <span>{label}</span>
  {isLink && <Icon name="lucide:external-link" class:list={[ext, 'opacity-40 transition group-hover/badge:opacity-90']} />}
</Tag>

---
import Icon from './Icon.astro';
import { Icon as Iconify } from 'astro-icon/components';
import ProjectIcon from './ProjectIcon.astro';
import TechBadge from './TechBadge.astro';
import { pick, localePath, useTranslations, type Lang } from '../i18n/utils';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  lang: Lang;
}
const { project, lang } = Astro.props;
const t = useTranslations(lang);
const href = localePath(lang, `projects/${project.slug}`);
const tags = project.tags.slice(0, 4);
const projectTitle = pick(project.title, lang);
---

<article
  class="reveal group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white/70 p-6 backdrop-blur transition hover:-translate-y-1 hover:border-brand-400/70 hover:shadow-xl hover:shadow-brand-500/10 dark:border-slate-800 dark:bg-slate-900/50 dark:hover:border-brand-400/60"
>
  <div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-brand-400 via-accent-500 to-blue-500 opacity-80 transition group-hover:opacity-100"></div>
  <div class="mb-4 flex items-start justify-between gap-3">
    <ProjectIcon icon={project.icon} label={projectTitle} />
    <div class="flex min-w-0 flex-col items-end gap-2 text-xs font-medium">
      <span class="max-w-full rounded-full bg-gradient-to-r from-brand-500/15 to-accent-500/15 px-2.5 py-1 text-right font-mono text-brand-600 dark:text-brand-300">
        {pick(project.category, lang)}
      </span>
      <span class="font-mono text-slate-400">{project.year}</span>
    </div>
  </div>

  {
    project.badge && (
      <span class="mb-2 inline-flex w-fit items-center gap-1 rounded-md bg-amber-400/15 px-2 py-0.5 font-mono text-[11px] font-semibold text-amber-700 ring-1 ring-amber-400/30 dark:text-amber-300">
        <Iconify name="lucide:graduation-cap" class="h-3 w-3" />
        {pick(project.badge, lang)}
      </span>
    )
  }

  <h3 class="text-lg font-semibold tracking-tight">
    <a href={href} class="transition group-hover:text-brand-500 before:absolute before:inset-0 before:content-['']">
      {projectTitle}
    </a>
  </h3>
  <p class="mt-2 flex-1 text-sm text-slate-500 dark:text-slate-400">
    {pick(project.tagline, lang)}
  </p>

  <div class="mt-4 flex flex-wrap gap-1.5">
    {tags.map((tag) => <TechBadge label={tag} size="sm" />)}
  </div>

  <div class="mt-5 flex items-center justify-between border-t border-slate-100 pt-4 dark:border-slate-800">
    <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-600 dark:text-brand-400">
      {t('projects.viewCase')}
      <Icon name="arrow-right" class="h-4 w-4 transition group-hover:translate-x-1" />
    </span>
    <div class="relative z-10 flex items-center gap-2">
      {
        project.demo && (
          <a
            href={project.demo}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t('projects.demo')}
            title={t('projects.demo')}
            class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-slate-400 transition hover:bg-brand-500/10 hover:text-brand-500"
          >
            <Icon name="external" class="h-4 w-4" />
          </a>
        )
      }
      <a
        href={project.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={t('projects.repo')}
        title={t('projects.repo')}
        class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-slate-400 transition hover:bg-brand-500/10 hover:text-brand-500"
      >
        <Icon name="github" class="h-4 w-4" />
      </a>
    </div>
  </div>
</article>

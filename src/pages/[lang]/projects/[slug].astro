---
import Base from '../../../layouts/Base.astro';
import Icon from '../../../components/Icon.astro';
import { projects, getProject } from '../../../data/projects';
import { profile } from '../../../data/site';
import { pick, localePath, useTranslations, locales, type Lang } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.flatMap((lang) =>
    projects.map((p) => ({ params: { lang, slug: p.slug } })),
  );
}

const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;
const t = useTranslations(lang);
const project = getProject(slug);
if (!project) return Astro.redirect(localePath(lang, 'projects'));

const highlights = pick(project.highlights, lang);
const results = project.results ? pick(project.results, lang) : null;
const title = `${pick(project.title, lang)} · ${profile.name}`;
const description = pick(project.tagline, lang);
---

<Base lang={lang} title={title} description={description} path={`projects/${slug}`}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <a
      href={localePath(lang, 'projects')}
      class="inline-flex items-center gap-1.5 text-sm text-slate-500 transition hover:text-brand-500"
    >
      <Icon name="arrow-right" class="h-4 w-4 rotate-180" />
      {t('projects.backToProjects')}
    </a>

    <header class="mt-6">
      <div class="flex items-center gap-3 text-xs font-medium">
        <span class="rounded-full bg-brand-500/10 px-2.5 py-1 font-mono text-brand-600 dark:text-brand-300">
          {pick(project.category, lang)}
        </span>
        <span class="text-slate-400">{project.year}</span>
      </div>
      <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">{pick(project.title, lang)}</h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-300">{pick(project.tagline, lang)}</p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700 dark:bg-white dark:text-slate-950 dark:hover:bg-slate-200"
        >
          <Icon name="github" class="h-4 w-4" />
          {t('projects.repo')}
        </a>
        {
          project.demo && (
            <a
              href={project.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold transition hover:border-brand-400 hover:text-brand-500 dark:border-slate-700"
            >
              <Icon name="external" class="h-4 w-4" />
              {t('projects.demo')}
            </a>
          )
        }
      </div>
    </header>

    <hr class="my-8 border-slate-200 dark:border-slate-800" />

    <section>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
        {t('projects.context')}
      </h2>
      <p class="mt-3 leading-relaxed text-slate-600 dark:text-slate-300">{pick(project.context, lang)}</p>
    </section>

    <section class="mt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
        {t('projects.highlights')}
      </h2>
      <ul class="mt-3 space-y-2">
        {
          highlights.map((h) => (
            <li class="flex gap-3 text-slate-600 dark:text-slate-300">
              <span class="mt-2.5 h-1.5 w-1.5 flex-none rounded-full bg-brand-500" />
              <span>{h}</span>
            </li>
          ))
        }
      </ul>
    </section>

    {
      results && (
        <section class="mt-8 rounded-2xl border border-brand-500/30 bg-brand-500/5 p-5">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
            {t('projects.results')}
          </h2>
          <ul class="mt-3 space-y-2">
            {results.map((r) => (
              <li class="flex gap-3 text-slate-700 dark:text-slate-200">
                <span class="mt-2.5 h-1.5 w-1.5 flex-none rounded-full bg-brand-500" />
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="mt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
        {t('projects.stack')}
      </h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {
          project.stack.map((s) => (
            <span class="rounded-lg bg-slate-100 px-3 py-1 font-mono text-xs text-slate-700 dark:bg-slate-800 dark:text-slate-300">
              {s}
            </span>
          ))
        }
      </div>
    </section>
  </article>
</Base>

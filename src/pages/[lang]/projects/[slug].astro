---
import Base from '../../../layouts/Base.astro';
import Icon from '../../../components/Icon.astro';
import { Icon as Iconify } from 'astro-icon/components';
import TechBadge from '../../../components/TechBadge.astro';
import { projects, getProject } from '../../../data/projects';
import { profile } from '../../../data/site';
import { pick, localePath, useTranslations, locales, type Lang } from '../../../i18n/utils';

export function getStaticPaths() {
  return locales.flatMap((lang) =>
    projects.map((p) => ({ params: { lang, slug: p.slug } })),
  );
}

const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;
const t = useTranslations(lang);
const project = getProject(slug);
if (!project) return Astro.redirect(localePath(lang, 'projects'));

const highlights = pick(project.highlights, lang);
const results = project.results ? pick(project.results, lang) : null;
const title = `${pick(project.title, lang)} · ${profile.name}`;
const description = pick(project.tagline, lang);
---

<Base lang={lang} title={title} description={description} path={`projects/${slug}`}>
  <article class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-14">
    <a
      href={localePath(lang, 'projects')}
      class="inline-flex items-center gap-1.5 text-sm text-slate-500 transition hover:text-brand-500"
    >
      <Icon name="arrow-right" class="h-4 w-4 rotate-180" />
      {t('projects.backToProjects')}
    </a>

    <header class="relative mt-6 overflow-hidden rounded-3xl border border-slate-200 bg-gradient-to-br from-brand-500/10 via-transparent to-accent-500/10 p-7 dark:border-slate-800">
      <div class="bg-grid pointer-events-none absolute inset-0 opacity-40 [mask-image:radial-gradient(ellipse_at_top_left,black,transparent_70%)]"></div>
      <div class="relative">
        <div class="flex flex-wrap items-center gap-3 text-xs font-medium">
          <span class="rounded-full bg-gradient-to-r from-brand-500/20 to-accent-500/20 px-2.5 py-1 font-mono text-brand-600 dark:text-brand-200">
            {pick(project.category, lang)}
          </span>
          {
            project.badge && (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-400/15 px-2.5 py-1 font-mono text-amber-700 ring-1 ring-amber-400/30 dark:text-amber-300">
                <Iconify name="lucide:graduation-cap" class="h-3.5 w-3.5" />
                {pick(project.badge, lang)}
              </span>
            )
          }
          <span class="font-mono text-slate-400">{project.year}</span>
        </div>
        <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">{pick(project.title, lang)}</h1>
        <p class="mt-3 text-lg text-slate-600 dark:text-slate-300">{pick(project.tagline, lang)}</p>

        <div class="mt-6 flex flex-wrap gap-3">
          {
            project.demo && (
              <a
                href={project.demo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-4 py-2 text-sm font-semibold text-slate-950 shadow-lg shadow-brand-500/20 transition hover:bg-brand-400"
              >
                <Icon name="external" class="h-4 w-4" />
                {t('projects.demo')}
              </a>
            )
          }
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold transition hover:border-brand-400 hover:text-brand-500 dark:border-slate-700"
          >
            <Icon name="github" class="h-4 w-4" />
            {t('projects.repo')}
          </a>
        </div>
      </div>
    </header>

    <section class="reveal mt-10">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
        {t('projects.context')}
      </h2>
      <p class="mt-3 leading-relaxed text-slate-600 dark:text-slate-300">{pick(project.context, lang)}</p>
    </section>

    <section class="reveal mt-9">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
        {t('projects.highlights')}
      </h2>
      <ul class="mt-4 space-y-2.5">
        {
          highlights.map((h) => (
            <li class="flex gap-3 text-slate-600 dark:text-slate-300">
              <Iconify name="lucide:check" class="mt-1 h-4 w-4 flex-none text-brand-500" />
              <span>{h}</span>
            </li>
          ))
        }
      </ul>
    </section>

    {
      results && (
        <section class="reveal mt-9 rounded-2xl border border-brand-500/30 bg-brand-500/5 p-5">
          <h2 class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
            <Iconify name="lucide:trending-up" class="h-4 w-4" />
            {t('projects.results')}
          </h2>
          <ul class="mt-4 grid gap-2.5 sm:grid-cols-2">
            {results.map((r) => (
              <li class="flex gap-3 text-slate-700 dark:text-slate-200">
                <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-brand-500" />
                <span>{r}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="reveal mt-9">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-600 dark:text-brand-400">
        {t('projects.stack')}
      </h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {project.stack.map((s) => <TechBadge label={s} size="md" link />)}
      </div>
    </section>
  </article>
</Base>

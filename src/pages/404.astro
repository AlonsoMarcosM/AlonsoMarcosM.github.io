---
import Base from '../layouts/Base.astro';
import { useTranslations } from '../i18n/utils';
const lang = 'en' as const;
const t = useTranslations(lang);
---

<Base lang={lang} title="404 · Alonso Marcos Muñoz" description="Page not found">
  <div class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center px-4 text-center">
    <p class="font-mono text-6xl font-bold text-brand-500">404</p>
    <h1 class="mt-4 text-2xl font-bold">{t('notfound.title')}</h1>
    <p class="mt-2 text-slate-500 dark:text-slate-400">{t('notfound.text')}</p>
    <div class="mt-6 flex gap-3">
      <a href="/en/" class="rounded-lg bg-brand-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-brand-400">English</a>
      <a href="/es/" class="rounded-lg border border-slate-300 px-5 py-2.5 text-sm font-semibold transition hover:border-brand-400 hover:text-brand-500 dark:border-slate-700">Español</a>
    </div>
  </div>
</Base>
